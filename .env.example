# PostgreSQL (Neon, Supabase, Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/rove_hire"

# Local dev only — on Vercel this is auto-set from VERCEL_URL if omitted
NEXTAUTH_URL="http://localhost:3000"

# Required on Vercel — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="rove-hire-dev-secret-change-in-production"

# Supabase storage (resume uploads)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

UPLOAD_DIR="./uploads"
